# ---- VLATune .gitignore ----
# Reproducibility lives in scripts/docs, NOT in large binaries. Keep those out.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.python-version

# Conda / venv
.venv/
env/
venv/

# Model checkpoints & weights (pull from the Hub instead)
*.safetensors
*.ckpt
*.pt
*.pth
*.bin
checkpoints/
pretrained/

# Datasets & HF cache (use streaming / the compact dataset; never commit ~GB data)
data/
datasets/
*.hdf5
*.parquet
.cache/
hf_cache/

# Training / eval outputs
outputs/
eval_logs/
results/**/*.mp4
results/**/*.png
# ...but DO keep small result JSONs and the dir itself
!results/.gitkeep
!results/**/*.json
# ...and DO keep the paper figures (generated by src/make_figures.py)
!results/figures/
!results/figures/*.png
!results/figures/*.pdf

# Rendered smoke-test artifacts
scripts/_render_smoke.png
*.mp4

# W&B
wandb/
.wandb/

# Secrets — NEVER commit these
.env
*.key
wandb_api_key*
hf_token*
.huggingface/

# Local reference scratch (third-party source pulled for inspection, e.g. lerobot v0.5.1)
_scratch_*/

# LaTeX build artifacts (keep main.tex, references.bib, figures/, and the built main.pdf)
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk
paper/*.toc
paper/_pg*.png

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
